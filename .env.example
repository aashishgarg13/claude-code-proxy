# ---- NVIDIA API Keys (2 keys for auto-rotation) ----
NVIDIA_API_KEY_1="nvapi-YOUR_FIRST_KEY"
NVIDIA_API_KEY_2="nvapi-YOUR_SECOND_KEY"

# ---- Google Gemini API Keys (2 keys for auto-rotation) ----
GEMINI_API_KEY_1="AIza-YOUR_FIRST_KEY"
GEMINI_API_KEY_2="AIza-YOUR_SECOND_KEY"

# ---- Backward compatibility ----
NVIDIA_API_KEY="nvapi-YOUR_KEY"
GEMINI_API_KEY="AIza-YOUR_KEY"
